<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:StrataTheme.Controls">

  <Styles.Resources>
    <ResourceDictionary>
      <ControlTheme x:Key="{x:Type controls:StrataChatTranscript}" TargetType="controls:StrataChatTranscript">
        <Setter Property="Template">
          <ControlTemplate>
            <ItemsPresenter ItemsPanel="{TemplateBinding ItemsPanel}" />
          </ControlTemplate>
        </Setter>
      </ControlTheme>
    </ResourceDictionary>
  </Styles.Resources>

</Styles>